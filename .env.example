# Public portfolio demos should keep the deterministic, zero-cost mode.
AI_MODE=mock

# Set AI_MODE=openai and provide a key to enable live structured analysis.
OPENAI_API_KEY=
OPENAI_MODEL=gpt-5.5

# Set this to the deployed application URL for absolute social-preview metadata.
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Optional persistence. Keep these empty for the zero-cost demo repository.
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
